# --- Dependencies ---
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js Build Output ---
/.next/
/out/
/build

# --- Environment Secrets (CRITICAL) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
# Don't ignore .env.example (it's safe and helps the Agent know which keys to use)
!.env.example

# --- Supabase Specifics ---
# Ignore local Supabase DB migrations/configs if you use the CLI
.supabase/
supabase/.temp/

# --- Security & Debug ---
*.pem
*.key
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Testing ---
/coverage